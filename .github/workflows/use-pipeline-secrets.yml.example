# Copy this file to YOUR OTHER REPO as .github/workflows/use-pipeline-secrets.yml
# (remove the .example extension)
#
# Prerequisites in that repo's Settings → Secrets and variables → Actions:
#   SECRETS_API_URL  = https://your-pipeline-secrets-app.vercel.app  (no trailing slash)
#   PROJECT_ID       = uuid from Pipeline Secrets project page
#   DEPLOY_TOKEN     = pst_... token (generate once in dashboard, copy immediately)

name: Use Pipeline Secrets

on:
  workflow_dispatch:
  push:
    branches: [main]

jobs:
  run-with-secrets:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      # Loads every secret from your Pipeline Secrets project into $GITHUB_ENV
      # e.g. if you saved key SERVER_IP, you can use env.SERVER_IP in later steps
      - name: Fetch secrets from Pipeline Secrets
        env:
          SECRETS_API_URL: ${{ secrets.SECRETS_API_URL }}
          PROJECT_ID: ${{ secrets.PROJECT_ID }}
          DEPLOY_TOKEN: ${{ secrets.DEPLOY_TOKEN }}
        run: |
          set -euo pipefail

          response=$(curl -sS -f -X POST "${SECRETS_API_URL}/api/ci/secrets" \
            -H "Content-Type: application/json" \
            -d "{\"projectId\":\"${PROJECT_ID}\",\"token\":\"${DEPLOY_TOKEN}\"}")

          echo "$response" | jq -r '.env | to_entries[] | "\(.key)=\(.value)"' | while IFS= read -r line; do
            key="${line%%=*}"
            value="${line#*=}"
            echo "::add-mask::${value}"
            echo "${key}=${value}" >> "$GITHUB_ENV"
          done

      # Example: use SERVER_IP (must match the key name in Pipeline Secrets exactly)
      - name: Deploy or SSH using server IP
        env:
          SERVER_IP: ${{ env.SERVER_IP }}
        run: |
          echo "Connecting to server (IP is masked in logs)..."
          # ssh deploy@$SERVER_IP './deploy.sh'
          # curl -f "http://${SERVER_IP}/health"
          # rsync -avz ./dist/ deploy@${SERVER_IP}:/var/www/app/
